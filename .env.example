# 환경변수 예시. 실 .env 는 git 에 안 올림 (.gitignore 처리됨).
# production = GitHub Secrets 에 등록 (T-M8.2).

# 사장님 시트 ID (URL 의 /d/ 와 /edit 사이)
# 실 값은 GitHub Secrets 또는 사장님 로컬 .env 에 등록. 이 파일은 placeholder.
SPREADSHEET_ID=YOUR_SPREADSHEET_ID_HERE

# 서비스 계정 JSON (T-M3.1 에서 다운로드한 JSON 파일 내용 전체)
# 로컬 개발: 파일 내용 한 줄로 변환해서 여기 붙이기 (또는 SERVICE_ACCOUNT_JSON_PATH 사용)
SERVICE_ACCOUNT_JSON=

# 사장님 운영 카페 slug 화이트리스트 (콤마 구분).
# 예: "cosmania,pusanmommy,iroid,workee" — 사장님 운영 카페 모든 slug.
# 미설정 시 = D-026 빈 link 자동 채움 X (= 안전 default).
CAFE_WHITELIST_SLUGS=

# 네이버 슬로우다운 (기본값 OK)
NAVER_SLOWDOWN_BASE_SEC=1.5
NAVER_SLOWDOWN_MAX_SEC=60

# ───────── 카페외부 재료수집 (cafe-material-collect.yml) ─────────
# [지식인 수집] 네이버 개발자센터 무료 앱 키(검색 API). 미설정 시 지식인 채널 스킵(안전).
NAVER_OPENAPI_CLIENT_ID=
NAVER_OPENAPI_CLIENT_SECRET=

# [리뷰 수집] Apify 유료 토큰. 미설정 시 리뷰 채널 스킵(안전).
APIFY_TOKEN=
# 액터 id (기본=검증된 추천 액터). 다른 액터 쓸 때만 변경.
APIFY_ACTOR_ID=accurate_dancer~naver-smart-store-monitor
# 추천 액터는 brandUrls(브랜드 슬러그) 입력 + includeReviews=true 필수(2026-06-20 공식페이지 검증).
# 상품 URL 입력 액터면 APIFY_INPUT_FIELD=productUrls 로 변경.
APIFY_INPUT_FIELD=brandUrls
APIFY_INCLUDE_REVIEWS=true
APIFY_MAX_REVIEW_PAGES=3
